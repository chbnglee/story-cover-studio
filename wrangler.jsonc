{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "story-cover-studio",
  "main": "worker.js",
  "compatibility_date": "2026-06-23",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
